<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="550.0" minWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="agh.ics.oop.presenter.Presenter">
   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <Canvas fx:id="canvas" height="200.0" width="200.0" />
         </children>
      </VBox>
   </center>
   <top>
      <VBox BorderPane.alignment="TOP_LEFT">
         <children>
            <TextField fx:id="movesTextField" promptText="f  f  f r l f b">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </TextField>
            <Button mnemonicParsing="false" onAction="#onSimulationStartClicked" text="start">
               <VBox.margin>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </top>
    <center>
        <Label text="Simalutations Start Screen"/>
    </center>
   <padding>
      <Insets right="20.0" />
   </padding>
</BorderPane>
